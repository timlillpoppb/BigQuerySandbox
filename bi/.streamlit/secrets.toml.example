# Copy this file to secrets.toml for local dev, or paste each section
# into the Streamlit Community Cloud "Secrets" editor for deployment.
# NEVER commit secrets.toml to git.

# --- BigQuery dataset override (optional) ---
# Defaults to prod_dataset_gold if omitted.
[bigquery]
dataset = "prod_dataset_gold"

# --- GCP service account (required in Streamlit Cloud) ---
# Create a key for a read-only BigQuery service account and paste the
# full JSON content here as a TOML table.
[gcp_service_account]
type = "service_account"
project_id = "project-2ac71b10-d4cb-403a-b2c"
private_key_id = "KEY_ID"
private_key = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email = "SERVICE_ACCOUNT_EMAIL@project-2ac71b10-d4cb-403a-b2c.iam.gserviceaccount.com"
client_id = "CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/SERVICE_ACCOUNT_EMAIL"
